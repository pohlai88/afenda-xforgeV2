{
  "$schema": "./tokens.schema.json",
  "metadata": {
    "version": 1,
    "source": "Afenda design-system tokens",
    "description": "Design data for Afenda CSS variables, Figma variables, and token governance.",
    "categories": {
      "color": {
        "description": "Primitive, semantic, brand, status, and operational surface colors.",
        "type": "color",
        "sourceOfTruth": "tokens.json -> globals.css CSS variables",
        "cssPrefix": "--xforge-color-",
        "figmaCollection": "Afenda / Color",
        "usage": "Use semantic color aliases in components; primitive colors are for token authors and CSS variable generation."
      },
      "radius": {
        "description": "Shared radius scale for inputs, cards, panels, modals, and focusable surfaces.",
        "type": "dimension",
        "sourceOfTruth": "tokens.json -> globals.css CSS variables",
        "cssPrefix": "--xforge-radius-",
        "figmaCollection": "Afenda / Shape",
        "usage": "Use component radius variables first; use primitive radius only in recipes and layout primitives."
      },
      "spacing": {
        "description": "Compact ERP spacing scale for dense dashboards, forms, tables, and panels.",
        "type": "dimension",
        "sourceOfTruth": "tokens.json -> globals.css CSS variables",
        "cssPrefix": "--xforge-space-",
        "figmaCollection": "Afenda / Spacing",
        "usage": "Use recipe gaps and component padding before one-off spacing utilities."
      },
      "layout": {
        "description": "Named layout dimensions for shell rails and persistent work areas.",
        "type": "dimension",
        "sourceOfTruth": "tokens.json -> globals.css CSS variables",
        "cssPrefix": "--xforge-layout-",
        "figmaCollection": "Afenda / Layout",
        "usage": "Use only for stable shell-level dimensions, not one-off component widths."
      },
      "typography": {
        "description": "Role-based typography for titles, body copy, labels, metrics, and captions.",
        "type": "typography",
        "sourceOfTruth": "tokens.json -> globals.css CSS variables",
        "cssPrefix": "--xforge-font-",
        "figmaCollection": "Afenda / Typography",
        "usage": "Use Text and MetricText primitives or recipe typography classes before raw font utilities."
      },
      "shadow": {
        "description": "Elevation tokens for panels, overlays, and dark-mode equivalents.",
        "type": "shadow",
        "sourceOfTruth": "tokens.json -> globals.css CSS variables",
        "cssPrefix": "--xforge-shadow-",
        "figmaCollection": "Afenda / Elevation",
        "usage": "Use panel and overlay elevations only; avoid decorative glow effects."
      },
      "motion": {
        "description": "Low-motion duration and easing tokens for operator interfaces.",
        "type": "motion",
        "sourceOfTruth": "tokens.json -> globals.css CSS variables",
        "cssPrefix": "--xforge-",
        "figmaCollection": "Afenda / Motion",
        "usage": "Animate color, opacity, and transform only; do not animate layout properties."
      },
      "zIndex": {
        "description": "Layering scale for dropdowns, sticky UI, modals, toast, and tooltips.",
        "type": "number",
        "sourceOfTruth": "tokens.json -> globals.css CSS variables",
        "cssPrefix": "--xforge-z-",
        "figmaCollection": "Afenda / Layer",
        "usage": "Use named layers only; do not create local arbitrary z-index values."
      }
    },
    "usageConstraints": {
      "primitive": {
        "allowedScopes": ["tokens", "globals.css", "recipes", "contract-tests"],
        "forbiddenScopes": ["app pages", "block-local styling"],
        "rule": "Primitive tokens may define raw values, but app and block code should consume semantic or component aliases."
      },
      "semantic": {
        "allowedScopes": ["components", "blocks", "recipes", "app composition"],
        "forbiddenScopes": ["raw palette redefinition"],
        "rule": "Semantic tokens express purpose and must be preferred over raw color and spacing values."
      },
      "component": {
        "allowedScopes": ["shared primitives", "blocks", "layout primitives"],
        "forbiddenScopes": ["single-use app styling"],
        "rule": "Component tokens are created only when multiple shared components need the same contract."
      },
      "warmth": {
        "allowedScopes": [
          "onboarding",
          "empty-state",
          "welcome-surface",
          "marketing",
          "illustration"
        ],
        "forbiddenScopes": [
          "data-table",
          "admin-form",
          "audit-log",
          "approval-queue",
          "dense-dashboard"
        ],
        "rule": "Warmth tokens are brand-expression tokens and must not encode operational status."
      }
    },
    "deprecation": {
      "policy": "Token removals require a migration guide entry, replacement token, and at least one release cycle with both old and new tokens available.",
      "deprecatedTokens": [],
      "reservedReplacementFields": ["replacement", "removeAfter", "reason"]
    },
    "figma": {
      "library": "Afenda Design System",
      "modeMap": {
        "light": "Light",
        "dark": "Dark"
      },
      "collections": {
        "primitive": "Afenda / Primitive",
        "semantic": "Afenda / Semantic",
        "component": "Afenda / Component"
      },
      "variableNameTemplate": "{layer}/{category}/{mode}/{name}",
      "tokenPathSeparator": "/",
      "exportRule": "Figma variables mirror token paths; CSS variable names remain the runtime contract."
    }
  },
  "color": {
    "canvas": "#F7F6F1",
    "raised": "#FFFFFF",
    "surface": "#EFEEE9",
    "ink": "#151515",
    "muted": "#5D655F",
    "line": "#D9D6CD",
    "brandPrimary": "#324038",
    "brandDark": "#243029",
    "brandSoft": "#55655B",
    "bark": "#795953",
    "doe": "#E8B793",
    "pink": "#F0DCCB",
    "info": "#3B6E8F",
    "warning": "#C58D2E",
    "warningForeground": "#94620F",
    "danger": "#B14E48",
    "success": "#2F7656",
    "focus": "#324038",
    "overlay": "#151515"
  },
  "radius": {
    "sm": "6px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px"
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "14px",
    "5": "16px",
    "6": "18px",
    "7": "22px",
    "8": "28px",
    "9": "36px"
  },
  "layout": {
    "sidebar": "248px",
    "auditRail": "324px"
  },
  "shadow": {
    "sm": "0 1px 2px rgb(21 21 21 / 8%)",
    "panel": "0 1px 2px rgb(21 21 21 / 8%), 0 8px 24px rgb(21 21 21 / 6%)",
    "popover": "0 18px 48px rgb(21 21 21 / 16%)",
    "darkPanel": "0 1px 2px rgb(4 7 6 / 42%), 0 12px 32px rgb(4 7 6 / 28%)",
    "darkPopover": "0 22px 54px rgb(4 7 6 / 42%)"
  },
  "motion": {
    "durationInstant": "80ms",
    "durationFast": "150ms",
    "durationNormal": "250ms",
    "durationSlow": "400ms",
    "easeOut": "cubic-bezier(0.16, 1, 0.3, 1)",
    "easeIn": "cubic-bezier(0.4, 0, 1, 1)",
    "easeInOut": "cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "zIndex": {
    "base": "0",
    "raised": "1",
    "dropdown": "10",
    "sticky": "20",
    "modalBackdrop": "30",
    "modal": "40",
    "toast": "50",
    "tooltip": "60"
  },
  "typography": {
    "title": {
      "fontFamily": "Inter",
      "fontSize": "30px",
      "fontWeight": "600",
      "lineHeight": "36px"
    },
    "body": {
      "fontFamily": "Inter",
      "fontSize": "13px",
      "fontWeight": "400",
      "lineHeight": "20px"
    },
    "label": {
      "fontFamily": "Inter",
      "fontSize": "11px",
      "fontWeight": "600",
      "lineHeight": "13px"
    },
    "metric": {
      "fontFamily": "Inter",
      "fontSize": "28px",
      "fontWeight": "600",
      "lineHeight": "34px"
    },
    "caption": {
      "fontFamily": "Inter",
      "fontSize": "12px",
      "fontWeight": "500",
      "lineHeight": "16px"
    }
  },
  "primitive": {
    "color": {
      "light": {
        "canvas": "#F7F6F1",
        "raised": "#FFFFFF",
        "surface": "#EFEEE9",
        "ink": "#151515",
        "muted": "#5D655F",
        "line": "#D9D6CD",
        "brandPrimary": "#324038",
        "brandDark": "#243029",
        "brandSoft": "#55655B",
        "bark": "#795953",
        "doe": "#E8B793",
        "pink": "#F0DCCB",
        "info": "#3B6E8F",
        "warning": "#C58D2E",
        "warningForeground": "#94620F",
        "danger": "#B14E48",
        "success": "#2F7656",
        "focus": "#324038",
        "overlay": "#151515"
      },
      "dark": {
        "canvas": "#111513",
        "raised": "#171D1A",
        "surface": "#232720",
        "ink": "#F2F0E8",
        "muted": "#BDB8AC",
        "line": "#3B3F37",
        "brandPrimary": "#A8BAAD",
        "brandDark": "#DCE0D7",
        "brandSoft": "#8FA095",
        "bark": "#C9A19B",
        "doe": "#EAC5AA",
        "pink": "#EED8CB",
        "info": "#8BB9D3",
        "warning": "#E1B35C",
        "warningForeground": "#E1B35C",
        "danger": "#F49E99",
        "success": "#8BC6A6",
        "focus": "#A8BAAD",
        "overlay": "#040706"
      }
    },
    "radius": {
      "sm": "6px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px"
    },
    "spacing": {
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "14px",
      "5": "16px",
      "6": "18px",
      "7": "22px",
      "8": "28px",
      "9": "36px"
    },
    "typography": {
      "title": "{typography.title}",
      "body": "{typography.body}",
      "label": "{typography.label}",
      "metric": "{typography.metric}",
      "caption": "{typography.caption}"
    },
    "shadow": {
      "sm": "{shadow.sm}",
      "panel": "{shadow.panel}",
      "popover": "{shadow.popover}"
    },
    "motion": {
      "durationInstant": "{motion.durationInstant}",
      "durationFast": "{motion.durationFast}",
      "durationNormal": "{motion.durationNormal}",
      "durationSlow": "{motion.durationSlow}",
      "easeOut": "{motion.easeOut}",
      "easeIn": "{motion.easeIn}",
      "easeInOut": "{motion.easeInOut}"
    },
    "zIndex": {
      "base": "{zIndex.base}",
      "raised": "{zIndex.raised}",
      "dropdown": "{zIndex.dropdown}",
      "sticky": "{zIndex.sticky}",
      "modalBackdrop": "{zIndex.modalBackdrop}",
      "modal": "{zIndex.modal}",
      "toast": "{zIndex.toast}",
      "tooltip": "{zIndex.tooltip}"
    }
  },
  "semantic": {
    "color": {
      "light": {
        "surfaceCanvas": "{primitive.color.light.canvas}",
        "surfaceRaised": "{primitive.color.light.raised}",
        "surfaceMuted": "{primitive.color.light.surface}",
        "surfaceHover": "color-mix(in oklab, var(--surface-muted) 45%, transparent)",
        "surfaceActive": "color-mix(in oklab, var(--surface-muted) 70%, transparent)",
        "surfaceOverlay": "{primitive.color.light.raised}",
        "surfaceInverse": "{primitive.color.light.ink}",
        "textPrimary": "{primitive.color.light.ink}",
        "textSecondary": "{primitive.color.light.muted}",
        "textInverse": "{primitive.color.light.raised}",
        "textLink": "{primitive.color.light.info}",
        "borderDefault": "{primitive.color.light.line}",
        "borderHover": "color-mix(in oklab, var(--xforge-color-line) 82%, var(--xforge-color-ink))",
        "borderFocus": "{primitive.color.light.focus}",
        "borderActive": "{primitive.color.light.focus}",
        "brandPrimary": "{primitive.color.light.brandPrimary}",
        "brandDark": "{primitive.color.light.brandDark}",
        "brandSoft": "{primitive.color.light.brandSoft}",
        "warmBark": "{primitive.color.light.bark}",
        "warmDoe": "{primitive.color.light.doe}",
        "warmPink": "{primitive.color.light.pink}",
        "statusSuccess": "{primitive.color.light.success}",
        "statusInfo": "{primitive.color.light.info}",
        "statusWarning": "{primitive.color.light.warningForeground}",
        "statusDanger": "{primitive.color.light.danger}"
      },
      "dark": {
        "surfaceCanvas": "{primitive.color.dark.canvas}",
        "surfaceRaised": "{primitive.color.dark.raised}",
        "surfaceMuted": "{primitive.color.dark.surface}",
        "surfaceHover": "color-mix(in oklab, var(--surface-muted) 45%, transparent)",
        "surfaceActive": "color-mix(in oklab, var(--surface-muted) 70%, transparent)",
        "surfaceOverlay": "{primitive.color.dark.raised}",
        "surfaceInverse": "{primitive.color.dark.ink}",
        "textPrimary": "{primitive.color.dark.ink}",
        "textSecondary": "{primitive.color.dark.muted}",
        "textInverse": "{primitive.color.dark.canvas}",
        "textLink": "{primitive.color.dark.info}",
        "borderDefault": "{primitive.color.dark.line}",
        "borderHover": "color-mix(in oklab, var(--xforge-color-line) 82%, white)",
        "borderFocus": "{primitive.color.dark.focus}",
        "borderActive": "{primitive.color.dark.focus}",
        "brandPrimary": "{primitive.color.dark.brandPrimary}",
        "brandDark": "{primitive.color.dark.brandDark}",
        "brandSoft": "{primitive.color.dark.brandSoft}",
        "warmBark": "{primitive.color.dark.bark}",
        "warmDoe": "{primitive.color.dark.doe}",
        "warmPink": "{primitive.color.dark.pink}",
        "statusSuccess": "{primitive.color.dark.success}",
        "statusInfo": "{primitive.color.dark.info}",
        "statusWarning": "{primitive.color.dark.warningForeground}",
        "statusDanger": "{primitive.color.dark.danger}"
      }
    },
    "shadow": {
      "raised": "{shadow.panel}",
      "overlay": "{shadow.popover}",
      "darkRaised": "{shadow.darkPanel}",
      "darkOverlay": "{shadow.darkPopover}"
    },
    "motion": {
      "hover": "color {motion.durationFast} {motion.easeOut}, background-color {motion.durationFast} {motion.easeOut}, border-color {motion.durationFast} {motion.easeOut}",
      "panelIn": "opacity {motion.durationNormal} {motion.easeOut}, transform {motion.durationNormal} {motion.easeOut}",
      "panelOut": "opacity {motion.durationFast} {motion.easeIn}, transform {motion.durationFast} {motion.easeIn}"
    }
  },
  "component": {
    "button": {
      "radius": "{primitive.radius.md}",
      "height": "36px",
      "paddingX": "{primitive.spacing.4}",
      "focusRing": "{semantic.color.light.borderFocus}"
    },
    "card": {
      "radius": "{primitive.radius.lg}",
      "padding": "{primitive.spacing.5}",
      "shadow": "{semantic.shadow.raised}"
    },
    "pill": {
      "radius": "{primitive.radius.sm}",
      "paddingX": "{primitive.spacing.2}",
      "paddingY": "{primitive.spacing.1}"
    },
    "modal": {
      "radius": "{primitive.radius.xl}",
      "shadow": "{semantic.shadow.overlay}",
      "zIndex": "{primitive.zIndex.modal}"
    }
  },
  "contrast": {
    "method": "WCAG 2.2 AA plus APCA Lc estimate",
    "pairs": [
      {
        "name": "light text primary on canvas",
        "foreground": "primitive.color.light.ink",
        "background": "primitive.color.light.canvas",
        "minWcag": 7,
        "minApca": 75
      },
      {
        "name": "light text secondary on canvas",
        "foreground": "primitive.color.light.muted",
        "background": "primitive.color.light.canvas",
        "minWcag": 4.5,
        "minApca": 60
      },
      {
        "name": "light brand primary on canvas",
        "foreground": "primitive.color.light.brandPrimary",
        "background": "primitive.color.light.canvas",
        "minWcag": 4.5,
        "minApca": 60
      },
      {
        "name": "light inverse text on brand primary",
        "foreground": "primitive.color.light.raised",
        "background": "primitive.color.light.brandPrimary",
        "minWcag": 4.5,
        "minApca": 60
      },
      {
        "name": "light status warning on panel",
        "foreground": "primitive.color.light.warningForeground",
        "background": "primitive.color.light.raised",
        "minWcag": 4.5,
        "minApca": 60
      },
      {
        "name": "light status danger on panel",
        "foreground": "primitive.color.light.danger",
        "background": "primitive.color.light.raised",
        "minWcag": 4.5,
        "minApca": 60
      },
      {
        "name": "dark text primary on canvas",
        "foreground": "primitive.color.dark.ink",
        "background": "primitive.color.dark.canvas",
        "minWcag": 7,
        "minApca": 75
      },
      {
        "name": "dark text secondary on canvas",
        "foreground": "primitive.color.dark.muted",
        "background": "primitive.color.dark.canvas",
        "minWcag": 4.5,
        "minApca": 60
      },
      {
        "name": "dark status danger on canvas",
        "foreground": "primitive.color.dark.danger",
        "background": "primitive.color.dark.canvas",
        "minWcag": 4.5,
        "minApca": 60
      }
    ]
  }
}
