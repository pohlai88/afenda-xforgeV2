{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "paths": {
      "@repo/*": ["../../packages/*"],
      "@repo/design-system/*": ["../../packages/design-system/*"]
    }
  },
  "include": [
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "stories/**/*.ts",
    "stories/**/*.tsx",
    "../../packages/design-system/**/*.ts",
    "../../packages/design-system/**/*.tsx"
  ],
  "exclude": ["node_modules", "storybook-static", "coverage"]
}
