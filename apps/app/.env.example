# Vercel Blob (@repo/storage) — multi-store; each store needs its own rw token
# Public store: afenda-xfroge-public (CMS images, Orbit Case attachments)
XFORGE_PUB_BLOB_READ_WRITE_TOKEN=""
XFORGE_PUB_STORE_ID=""
# Private store: afenda-xfroge-sensitive (server-only via readPrivateBlob)
