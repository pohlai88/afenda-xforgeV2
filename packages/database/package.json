{
  "name": "@repo/database",
  "version": "0.0.0",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./schema": "./schema.ts"
  },
  "scripts": {
    "build": "node -e \"console.log('@repo/database build skipped (types via typecheck)')\"",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.21.0",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "25.3.5",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3"
  }
}
