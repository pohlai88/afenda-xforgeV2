{
  "name": "@repo/cms",
  "version": "0.0.0",
  "private": true,
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./components/body": "./components/body.tsx",
    "./components/image": "./components/image.tsx",
    "./components/toc": "./components/toc.tsx"
  },
  "scripts": {
    "dev": "node -e \"console.log('@repo/cms uses git-backed MDX; no dev server required.')\"",
    "build": "node -e \"console.log('@repo/cms build skipped (file-based content)')\"",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "mdx-bundler": "^10.1.1",
    "react": "19.2.4",
    "rehype-pretty-code": "^0.14.1",
    "rehype-slug": "^6.0.0",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "next": "16.1.6",
    "typescript": "^5.9.3"
  }
}
