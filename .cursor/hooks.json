{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "prompt",
        "prompt": "Repo: afenda-Xforge (afenda-xforge, pnpm, apps/app Next.js 16+). Rules: AGENTS.md + .cursor/rules/ (project-general.mdc index). Skill: .cursor/skills/xforge-nextjs-vercel/ for Next.js + Vercel. apps/app: MCP init(project_path=apps/app) + nextjs_docs (after llms-index) before any Next.js code. Hooks enforce: NEXT_PUBLIC secrets, Vercel prod deploy/MCP deploy/env pull, destructive git, dev servers, design-system primitives, stop quality gates."
      }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/hooks/guard-workspace-compose.mjs",
        "timeout": 5
      },
      {
        "command": "node .cursor/hooks/guard-next-public-env.mjs",
        "timeout": 5
      },
      {
        "command": "node .cursor/hooks/guard-synced-env.mjs",
        "timeout": 5
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/block-destructive-git.mjs",
        "timeout": 5
      },
      {
        "command": "node .cursor/hooks/block-dev-servers.mjs",
        "timeout": 5
      },
      {
        "command": "node .cursor/hooks/warn-wrong-package-manager.mjs",
        "timeout": 5
      },
      {
        "command": "node .cursor/hooks/ask-vercel-production.mjs",
        "timeout": 5
      },
      {
        "command": "node .cursor/hooks/ask-vercel-env-pull.mjs",
        "timeout": 5
      },
      {
        "command": "node .cursor/hooks/guard-synced-env.mjs",
        "timeout": 5
      },
      {
        "command": "node .cursor/hooks/guard-drizzle-migrate.mjs",
        "timeout": 5
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "node .cursor/hooks/guard-vercel-deploy-mcp.mjs",
        "timeout": 5
      },
      {
        "command": "node .cursor/hooks/guard-drizzle-migrate.mjs",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/stop-quality-gates.mjs",
        "timeout": 180,
        "loop_limit": 3
      }
    ]
  }
}
