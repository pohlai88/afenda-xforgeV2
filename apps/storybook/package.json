{
  "name": "storybook",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build",
    "a11y:report": "node -e \"require('node:fs').rmSync('.storybook/a11y-reports',{recursive:true,force:true})\" && test-storybook --ci --url http://127.0.0.1:6006 --maxWorkers 1 --testTimeout 60000 --skipTags visual-audit",
    "chromatic": "chromatic --exit-zero-on-changes --config-file chromatic.config.json",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "test-storybook": "test-storybook --url http://127.0.0.1:6006 --skipTags visual-audit",
    "test-storybook:ci": "test-storybook --ci --url http://127.0.0.1:6006 --maxWorkers 1 --testTimeout 60000 --skipTags visual-audit",
    "test-storybook:interaction": "test-storybook --ci --url http://127.0.0.1:6006 --maxWorkers 2 --testTimeout 20000 --includeTags interaction --skipTags visual-audit",
    "test-storybook:interaction:watch": "test-storybook --url http://127.0.0.1:6006 --watch --maxWorkers 1 --testTimeout 20000 --includeTags interaction --skipTags visual-audit",
    "test-storybook:coverage": "test-storybook --ci --url http://127.0.0.1:6006 --coverage --coverageDirectory coverage/storybook --maxWorkers 1 --testTimeout 60000 --skipTags visual-audit",
    "test-storybook:list": "test-storybook --url http://127.0.0.1:6006 --listTests --skipTags visual-audit",
    "test-storybook:snapshots": "test-storybook --ci --url http://127.0.0.1:6006 --maxWorkers 1 --testTimeout 60000 --skipTags visual-audit",
    "test-storybook:snapshots:update": "test-storybook --url http://127.0.0.1:6006 --updateSnapshot --maxWorkers 1 --testTimeout 60000 --skipTags visual-audit",
    "test-storybook:watch": "test-storybook --url http://127.0.0.1:6006 --watch --skipTags visual-audit",
    "test-storybook:visual": "chromatic --exit-zero-on-changes --config-file chromatic.config.json",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@repo/design-system": "workspace:*",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@repo/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-links": "^10.4.4",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-onboarding": "^10.2.16",
    "@storybook/addon-themes": "^10.2.16",
    "@storybook/nextjs": "^10.2.16",
    "@storybook/react": "^10.2.16",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "axe-playwright": "^2.2.2",
    "chromatic": "^15.2.0",
    "postcss": "^8",
    "storybook": "^10.2.16",
    "tailwindcss": "^4.2.1",
    "typescript": "^5"
  }
}
