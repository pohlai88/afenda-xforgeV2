{
  "name": "app-e2e",
  "private": true,
  "type": "module",
  "scripts": {
    "check:env": "tsx helpers/check-env.ts",
    "preflight": "cross-env E2E_CHECK_PROJECT=orbit-case tsx helpers/check-env.ts",
    "test": "node -e \"console.log('app-e2e Playwright suite is opt-in; run pnpm test:e2e')\"",
    "e2e": "playwright test",
    "test:auth": "cross-env PLAYWRIGHT_SKIP_GLOBAL_SETUP=1 playwright test --project=auth-flows",
    "test:orbit-case": "playwright test --project=authenticated --grep @orbit-case",
    "test:orbit-case:blob": "playwright test --project=authenticated-blob --grep @blob",
    "test:ui": "playwright test --ui",
    "install:browsers": "playwright install chromium",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@repo/typescript-config": "workspace:*",
    "cross-env": "^7.0.3",
    "tsx": "^4.20.3"
  }
}
